      },

      "action": {
        "actionType": "increase_rest_time",
        "actionValue": {
          "restTimeIncrease": 30,
          "newRestTime": 210,
          "maintainRepsMethod": "maintain_intensity",
          "maxIncrease": 60
        },
        "constraints": {
          "maxRestTime": 600,
          "minWeeksInRegress": 2,
          "requiresFeedback": true
        }
      },

      "conditions": {
        "goalBased": true,
