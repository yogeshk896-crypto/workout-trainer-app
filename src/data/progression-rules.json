{
  "progressionRules": [
    {
      "ruleId": "rep_progression_easy_feedback",
      "name": "Rep Progression from Easy Feedback",
      "description": "After 2 consecutive sessions marked 'easy' with all prescribed reps completed, increase reps by 2-3. Primary progression mechanism for building strength and endurance.",
      "ruleType": "progression",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveEasySessions": 2,
          "repsCompleted": true,
          "weeksInProgression": 2
        },
        "performance": {
          "completionRate": 1.0,
          "minimumReps": 6,
          "currentReps": "currentReps"
        },
        "userStatus": {
          "daysActive": 7,
          "exerciseLevel": "beginner",
          "currentFrequency": 3
        }
      },

      "exerciseState": {
        "currentDifficulty": "beginner",
        "currentReps": 10,
        "currentSets": 3,
        "currentWeight": null,
        "currentRestTime": 90
      },

      "action": {
        "actionType": "increase_reps",
        "actionValue": {
          "repsIncrease": 2,
          "newReps": null,
          "newSets": null,
          "newWeight": null,
          "adjustmentStrategy": "batch_increase"
        },
        "constraints": {
          "maxReps": 15,
          "minWeeksBeforeIncrease": 2,
          "maxDiesProgression": "intermediate",
          "requiresFeedback": true,
          "maxConsecutiveIncrease": 2,
          "maxWeeklyIncrease": 3
        }
      },

      "conditions": {
        "goalBased": true,
        "applicableGoals": ["muscle_gain", "general_fitness", "endurance", "fat_loss"],
        "notApplicableGoals": ["strength"],
        "equipmentRequired": [],
        "priority": "high",
        "blockable": true,
        "requiresNotification": true
      },

      "globalModifiers": {
        "maxWeeklyRepsIncrease": 3,
        "minWeeksInProgression": 2,
        "maxDifficulty": "advanced",
        "deloadPeriod": false
      }
    },

    {
      "ruleId": "set_progression_stalls",
      "name": "Set Progression After Rep Stalls",
      "description": "When user hits maximum prescribed reps for 3 consecutive sessions without progression, add 1 more set to increase total volume.",
      "ruleType": "progression",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveEasySessions": 3,
          "repsAtMaximum": true,
          "weeksInProgression": 3
        },
        "performance": {
          "completionRate": 1.0,
          "currentReps": "maxReps",
          "stalledReps": true,
          "stalledRepsWeeks": 3
        },
        "userStatus": {
          "daysActive": 14,
          "exerciseLevel": "intermediate",
          "currentFrequency": 3
        }
      },

      "exerciseState": {
        "currentDifficulty": "intermediate",
        "currentReps": 12,
        "currentSets": 3,
        "currentWeight": null,
        "currentRestTime": 90
      },

      "action": {
        "actionType": "increase_sets",
        "actionValue": {
          "setsIncrease": 1,
          "newSets": 4,
          "adjustedRepsMethod": "maintain_reps",
          "newWeight": null,
          "newRestTime": 90
        },
        "constraints": {
          "maxSets": 6,
          "minWeeksBeforeIncrease": 3,
          "requiresFeedback": true,
          "maxSetsBeforeRegress": 10
        }
      },

      "conditions": {
        "goalBased": true,
        "applicableGoals": ["muscle_gain", "endurance", "fat_loss"],
        "notApplicableGoals": ["strength"],
        "equipmentRequired": [],
        "priority": "high",
        "blockable": true
      },

      "globalModifiers": {
        "maxWeeklyRepsIncrease": 3,
        "minWeeksInProgression": 3,
        "maxDifficulty": "intermediate",
        "deloadPeriod": false
      }
    },

    {
      "ruleId": "rep_decrease_hard_feedback",
      "name": "Rep Decrease from Hard Feedback",
      "description": "When user marks exercise 'hard' for 2 consecutive sessions AND doesn't complete all prescribed reps, reduce reps by 2 to ensure successful completion.",
      "ruleType": "regression",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveHardSessions": 2,
          "repsCompleted": false,
          "weeksInProgression": 2
        },
        "performance": {
          "completionRate": "<0.8",
          "failedReps": true,
          "maxRepsAchieved": "currentReps - 1"
        },
        "userStatus": {
          "daysActive": 7,
          "exerciseLevel": "any",
          "currentFrequency": "any"
        }
      },

      "exerciseState": {
        "currentDifficulty": "any",
        "currentReps": "currentReps",
        "currentSets": "currentSets",
        "currentWeight": "currentWeight",
        "currentRestTime": "currentRestTime"
      },

      "action": {
        "actionType": "decrease_reps",
        "actionValue": {
          "repsDecrease": 2,
          "newReps": null,
          "newSets": "currentSets",
          "newRestTime": "currentRestTime + 30",
          "adjustedStrategy": "safer_completion"
        },
        "constraints": {
          "minReps": 4,
          "minWeeksInRegress": 1,
          "autoProgressAfter": true
        }
      },

      "conditions": {
        "goalBased": false,
        "universalRule": true,
        "equipmentRequired": [],
        "priority": "medium",
        "blockable": true,
        "requiresNotification": true
      },

      "globalModifiers": {
        "maxWeeklyRegressions": 1,
        "feedbackLikeRegressions": true,
        "deloadPeriod": false
      }
    },

    {
      "ruleId": "set_decrease_consistent_hard",
      "name": "Set Decrease from Consistent Hard Feedback",
      "description": "When user consistently struggles (3+ consecutive 'hard' feedback), reduce total sets to ensure workout completion without overtraining.",
      "ruleType": "regression",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveHardSessions": 3,
          "repsCompleted": false,
          "weeksInProgression": 3
        },
        "performance": {
          "completionRate": "<0.7",
          "failedSets": true,
          "tooManySets": true
        },
        "userStatus": {
          "daysActive": 14,
          "exerciseLevel": "any",
          "currentFrequency": "any"
        }
      },

      "exerciseState": {
        "currentDifficulty": "any",
        "currentReps": "currentReps",
        "currentSets": 5,
        "currentWeight": "currentWeight",
        "currentRestTime": "currentRestTime"
      },

      "action": {
        "actionType": "decrease_sets",
        "actionValue": {
          "setsDecrease": 1,
          "newSets": 4,
          "maintainRepsMethod": "maintain_completion_rate",
          "newRestTime": "currentRestTime + 15"
        },
        "constraints": {
          "minSets": 2,
          "minWeeksInRegress": 2,
          "checkAfter": 2
        }
      },

      "conditions": {
        "goalBased": false,
        "universalRule": true,
        "equipmentRequired": [],
        "priority": "medium",
        "blockable": true
      },

      "globalModifiers": {
        "maxWeeklyRegressions": 1,
        "feedbackLikeRegressions": true,
        "deloadPeriod": false
      }
    },

    {
      "ruleId": "rest_time_decrease_progression",
      "name": "Rest Time Decrease for Conditioning Goals",
      "description": "For users with conditioning/endurance goals, progressively reduce rest times between sets to improve work capacity and cardiovascular fitness.",
      "ruleType": "adaptation",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveEasySessions": 2,
          "repsCompleted": true,
          "goalIsConditioning": true
        },
        "performance": {
          "completionRate": 1.0,
          "maintainedQuality": true
        },
        "userStatus": {
          "exerciseGoal": "conditioning",
          "currentRestTime": 90
        }
      },

      "exerciseState": {
        "currentDifficulty": "beginner",
        "currentReps": 12,
        "currentSets": 3,
        "currentWeight": null,
        "currentRestTime": 90
      },

      "action": {
        "actionType": "decrease_rest_time",
        "actionValue": {
          "restTimeDecrease": 15,
          "newRestTime": 75,
          "maintainRepsMethod": "maintain_volume",
          "maxReduction": 30
        },
        "constraints": {
          "minRestTime": 30,
          "minWeeksInRegress": 1,
          "requiresFeedback": true
        }
      },

      "conditions": {
        "goalBased": true,
        "applicableGoals": ["endurance", "fat_loss", "general_fitness"],
        "notApplicableGoals": ["strength", "muscle_gain"],
        "equipmentRequired": [],
        "priority": "low",
        "blockable": true
      },

      "globalModifiers": {
        "minRestTime": 30,
        "restTimeFloor": 30,
        "priority": "secondary"
      }
    },

    {
      "ruleId": "rest_time_increase_strength",
      "name": "Rest Time Increase for Strength Goals",
      "description": "For users with strength goals, progressively increase rest times between sets to improve recovery and strength adaptation for heavy lifts.",
      "ruleType": "adaptation",
      
      "triggerCondition": {
        "feedback": {
          "consecutiveEasySessions": 3,
          "repsCompleted": true,
          "goalIsStrength": true,
          "liftingHeavy": true
        },
