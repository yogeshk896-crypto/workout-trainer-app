          "maintainedIntensity": true
        },
        "userStatus": {
          "exerciseGoal": "strength",
          "currentRestTime": 180
        }
      },

      "exerciseState": {
        "currentDifficulty": "intermediate",
        "currentReps": 5,
        "currentSets": 4,
        "currentWeight": "heavy",
