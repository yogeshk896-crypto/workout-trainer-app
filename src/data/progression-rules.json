    {
      "ruleId": "weekly_progression_caps",
      "name": "Weekly Progression Caps",
      "description": "Prevents users from increasing reps too quickly within a single week. Ensures progressive overload is gradual and sustainable.",
      "ruleType": "constraint",
      
      "triggerCondition": {
        "feedback": {
          "anyFeedback": true,
          "weeksInProgression": 1
        },
        "performance": {
          "singleDayProgress": true
        },
        "userStatus": {
          "exerciseGoal": "any",
          "currentReps": "currentReps"
        }
      },

      "exerciseState": {
        "currentDifficulty": "any",
        "currentReps": "currentReps",
        "currentSets": "currentSets",
        "currentWeight": "currentWeight",
        "currentRestTime": "currentRestTime"
      },

      "action": {
        "actionType": "prevent_excessive_progression",
        "actionValue": {
          "maxWeeklyRepsIncrease": 3,
          "maxWeeklySetsIncrease": 1,
          "enforcedLimit": "3_reps_per_week"
        },
        "constraints": {
          "rollingWeeklyCount": true,
          "enforced": true
        }
      },

      "conditions": {
        "goalBased": false,
        "universalRule": true,
        "equipmentRequired": [],
        "priority": "high",
        "nonNegotiable": true
      },

      "globalModifiers": {
        "enforcedLimit": "3_reps_per_week",
        "minimumProgress": "1_rep_when_appropriated"
      }
    },

    {
      "ruleId": "deload_week_cleanup",
      "name": "Deload Week Progression Clean",
      "description": "During deload weeks, pause progression and regression triggers. Prevents getting stuck in repetitive progression loops during recovery periods.",
      "ruleType": "adaptation",
      
      "triggerCondition": {
        "feedback": {
          "deloadWeek": true,
          "weeksInProgression": 4
        },
        "performance": {
          "deloadInProgress": true,
          "pausedProgression": true
        },
        "userStatus": {
          "exerciseGoal": "any",
          "deloadWeek": true
        }
      },

      "exerciseState": {
        "currentDifficulty": "any",
        "currentReps": "currentReps",
        "currentSets": "currentSets",
        "currentWeight": "currentWeight",
        "currentRestTime": "currentRestTime"
      },

      "action": {
        "actionType": "pause_progression_triggers",
        "actionValue": {
          "pausedRules": [
            "rep_progression_easy_feedback",
            "set_progression_stalls",
            "rep_decrease_hard_feedback"
          ],
          "duration": "1_week",
          "resumeAfterDeload": true
        },
        "constraints": {
          "pauseDuration": "1_week",
          "autoResume": true,
          "maintainCurrentLevel": true
        }
      },

      "conditions": {
        "goalBased": false,
        "universalRule": true,
        "equipmentRequired": [],
        "priority": "high",
        "nonNegotiable": true
      },

      "globalModifiers": {
        "enforcedLimit": "1_week_pause",
        "autoResume": true
      }
    },
   
    {
      "ruleId": "dumbbell_weight_progression",
